{
  "name": "tech-challenge-2",
  "private": true,
  "scripts": {
    "build": "npx turbo run build",
    "build:prod": "NODE_ENV=production turbo run build",
    "preview": "turbo run preview --filter=easemind-web",
    "preview:mfe-tasks": "turbo run preview --filter=mfe-tasks",
    "build:easemind-web": "turbo run build --filter=easemind-web",
    "build:mfe-tasks": "turbo run build --filter=mfe-tasks",
    "dev": "turbo dev --concurrency=12",
    "test": "turbo run test",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "check-types": "turbo run check-types",
    "json-server": "json-server --watch db.json --port 8080"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.1.0",
    "@testing-library/react": "^14.0.0",
    "@testing-library/user-event": "^14.5.0",
    "@types/jest": "^29.5.0",
    "concurrently": "^9.2.0",
    "happy-dom": "^20.8.3",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "json-server": "^1.0.0-beta.3",
    "prettier": "^3.5.3",
    "ts-jest": "^29.1.0",
    "turbo": "^2.5.4",
    "typescript": "5.8.2"
  },
  "engines": {
    "node": ">=18"
  },
  "packageManager": "yarn@1.22.22",
  "workspaces": [
    "apps/*",
    "packages/*"
  ]
}
